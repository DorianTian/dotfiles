# EditorConfig — universal baseline across all editors and IDEs
# https://editorconfig.org

root = true

# Default for all files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 120

# Go — tabs are the official standard
[*.go]
indent_style = tab
indent_size = 4

# Python — PEP 8 standard
[*.py]
indent_size = 4

# Makefile — must use tabs
[Makefile]
indent_style = tab

# Markdown — trailing whitespace can be intentional (line breaks)
[*.md]
trim_trailing_whitespace = false

# YAML
[*.{yml,yaml}]
indent_size = 2

# SQL
[*.sql]
indent_size = 4
