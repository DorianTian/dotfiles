{
  "name": "cursor-vscode-config",
  "version": "1.0.0",
  "private": true,
  "description": "Comprehensive code formatting config - Prettier, ESLint, Ruff, gofmt, sql-formatter",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:py": "ruff format .",
    "format:py:check": "ruff format --check .",
    "format:sql": "sql-formatter --config sql-formatter.json",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "check": "npm run format:check && npm run lint"
  },
  "dependencies": {
    "prettier": "^3.8.0",
    "prettier-plugin-sql": "^0.18.0",
    "sql-formatter": "^15.0.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-vue": "^9.30.0",
    "vue-eslint-parser": "^9.4.0",
    "globals": "^15.0.0"
  },
  "license": "MIT"
}
