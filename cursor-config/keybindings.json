[
    // ══ 用户原有 ══
    {
        "key": "alt+cmd+left",
        "command": "workbench.action.navigateBack",
        "when": "canNavigateBack"
    },
    {
        "key": "ctrl+-",
        "command": "-workbench.action.navigateBack",
        "when": "canNavigateBack"
    },
    {
        "key": "alt+cmd+right",
        "command": "workbench.action.navigateForward",
        "when": "canNavigateForward"
    },
    {
        "key": "ctrl+shift+-",
        "command": "-workbench.action.navigateForward",
        "when": "canNavigateForward"
    },
    {
        "key": "cmd+i",
        "command": "composerMode.agent"
    },
    {
        "key": "alt+cmd+s",
        "command": "workbench.action.toggleUnifiedSidebarFromKeyboard",
        "when": "cursor.agentIdeUnification.enabled == true && !isAuxiliaryWindowFocusedContext"
    },

    // ══════════════════════════════════════════════════════════
    // 窗口导航：Ctrl+h/j/k/l → 直接绑 VSCode action（不经过 neovim）
    // ══════════════════════════════════════════════════════════

    // Ctrl+h → 聚焦左侧编辑器组（覆盖默认 Find & Replace）
    {
        "key": "ctrl+h",
        "command": "-editor.action.startFindReplaceAction"
    },
    {
        "key": "ctrl+h",
        "command": "workbench.action.focusLeftGroup",
        "when": "editorTextFocus && neovim.mode != 'insert'"
    },

    // Ctrl+j → 聚焦下方编辑器组
    {
        "key": "ctrl+j",
        "command": "workbench.action.focusBelowGroup",
        "when": "editorTextFocus && neovim.mode != 'insert'"
    },

    // Ctrl+k → 聚焦上方编辑器组（覆盖默认 chord prefix）
    {
        "key": "ctrl+k",
        "command": "-extension.vim_ctrl+k",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+k",
        "command": "workbench.action.focusAboveGroup",
        "when": "editorTextFocus && neovim.mode != 'insert'"
    },

    // Ctrl+l → 聚焦右侧编辑器组
    {
        "key": "ctrl+l",
        "command": "-expandLineSelection",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+l",
        "command": "workbench.action.focusRightGroup",
        "when": "editorTextFocus && neovim.mode != 'insert'"
    },

    // ══════════════════════════════════════════════════════════
    // 终端切换
    // ══════════════════════════════════════════════════════════
    {
        "key": "ctrl+/",
        "command": "workbench.action.terminal.toggleTerminal"
    },
    {
        "key": "ctrl+\\",
        "command": "workbench.action.terminal.toggleTerminal"
    },

    // ══════════════════════════════════════════════════════════
    // Ctrl+D/U 半页滚动：normal/visual mode 显式发给 neovim
    // ══════════════════════════════════════════════════════════
    {
        "key": "ctrl+d",
        "command": "-editor.action.addSelectionToNextFindMatch"
    },
    {
        "key": "ctrl+d",
        "command": "vscode-neovim.send",
        "args": "<C-d>",
        "when": "editorTextFocus && neovim.init && neovim.mode != 'insert'"
    },
    {
        "key": "ctrl+u",
        "command": "-editor.action.cursorUndo"
    },
    {
        "key": "ctrl+u",
        "command": "vscode-neovim.send",
        "args": "<C-u>",
        "when": "editorTextFocus && neovim.init && neovim.mode != 'insert'"
    },

    // ══════════════════════════════════════════════════════════
    // Alt+j/k 移动行（macOS Alt 产生死键，必须在这里绑定）
    // ══════════════════════════════════════════════════════════
    {
        "key": "alt+j",
        "command": "editor.action.moveLinesDownAction",
        "when": "editorTextFocus && !suggestWidgetVisible"
    },
    {
        "key": "alt+k",
        "command": "editor.action.moveLinesUpAction",
        "when": "editorTextFocus && !suggestWidgetVisible"
    },

    // ══════════════════════════════════════════════════════════
    // 搜索结果导航（纯键盘）
    // 搜索框中 Ctrl+j → 跳到结果列表
    // 结果列表中 Ctrl+j/k → 上下浏览（不打开文件）
    // Enter → 打开选中的结果
    // ══════════════════════════════════════════════════════════
    {
        "key": "ctrl+j",
        "command": "search.action.focusSearchList",
        "when": "searchInputBoxFocus"
    },
    {
        "key": "ctrl+j",
        "command": "list.focusDown",
        "when": "listFocus && searchViewletVisible"
    },
    {
        "key": "ctrl+k",
        "command": "list.focusUp",
        "when": "listFocus && searchViewletVisible"
    }
]
