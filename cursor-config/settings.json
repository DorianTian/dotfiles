{
  // ══ 字体（对齐 Ghostty：JetBrainsMono + LXGW WenKai）══
  "editor.fontFamily": "'JetBrainsMono Nerd Font', 'LXGW WenKai Mono', monospace",
  "editor.fontSize": 16,
  "editor.fontWeight": "500",
  "editor.fontLigatures": "'calt', 'liga'",
  "editor.fontVariations": true,
  "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font', 'LXGW WenKai Mono', monospace",
  "terminal.integrated.fontSize": 16,
  "terminal.integrated.fontWeightBold": "bold",
  "terminal.integrated.fontLigatures.enabled": true,
  "debug.console.fontFamily": "'JetBrainsMono Nerd Font', 'LXGW WenKai Mono'",
  "debug.console.fontSize": 14,
  "scm.inputFontFamily": "'JetBrainsMono Nerd Font', 'LXGW WenKai Mono'",
  "scm.inputFontSize": 14,
  "notebook.markup.fontFamily": "'JetBrainsMono Nerd Font', 'LXGW WenKai Mono'",
  "notebook.markup.fontSize": 14,
  "notebook.output.fontFamily": "'JetBrainsMono Nerd Font', 'LXGW WenKai Mono'",
  "notebook.output.fontSize": 14,
  "editor.inlineSuggest.fontFamily": "'JetBrainsMono Nerd Font', 'LXGW WenKai Mono'",
  "editor.suggestFontSize": 14,
  "errorLens.fontFamily": "'JetBrainsMono Nerd Font', 'LXGW WenKai Mono'",
  "errorLens.fontSize": "13",
  // ══ 主题（Friday — CVD-adapted Modus Operandi Light）══
  "workbench.colorTheme": "Default Light Modern",
  "workbench.iconTheme": "vscode-jetbrains-icon-theme",
  "workbench.productIconTheme": "icons-carbon",
  "workbench.sideBar.location": "right",
  "window.commandCenter": true,
  "editor.semanticHighlighting.enabled": true,
  // ══ Friday 配色覆盖（终端 1:1 映射 + UI + 编辑器）══
  "workbench.colorCustomizations": {
    "[Default Light Modern]": {
      // --- 终端：精确映射 Ghostty Friday 16 色 palette ---
      "terminal.background": "#ffffff",
      "terminal.foreground": "#000000",
      "terminalCursor.foreground": "#000000",
      "terminalCursor.background": "#ffffff",
      "terminal.selectionBackground": "#bdbdbd",
      "terminal.selectionForeground": "#000000",
      "terminal.ansiBlack": "#000000",
      "terminal.ansiRed": "#9a4500",
      "terminal.ansiGreen": "#00576e",
      "terminal.ansiYellow": "#6f5500",
      "terminal.ansiBlue": "#0031a9",
      "terminal.ansiMagenta": "#721045",
      "terminal.ansiCyan": "#005e8b",
      "terminal.ansiWhite": "#a6a6a6",
      "terminal.ansiBrightBlack": "#595959",
      "terminal.ansiBrightRed": "#873500",
      "terminal.ansiBrightGreen": "#005a5a",
      "terminal.ansiBrightYellow": "#884900",
      "terminal.ansiBrightBlue": "#3548cf",
      "terminal.ansiBrightMagenta": "#531ab6",
      "terminal.ansiBrightCyan": "#005f5f",
      "terminal.ansiBrightWhite": "#595959",
      // --- 编辑器 ---
      "editor.background": "#ffffff",
      "editor.foreground": "#000000",
      "editor.selectionBackground": "#bdbdbd",
      "editor.selectionForeground": "#000000",
      "editorCursor.foreground": "#000000",
      "editor.lineHighlightBackground": "#f2f2f2",
      "editorLineNumber.foreground": "#a6a6a6",
      "editorLineNumber.activeForeground": "#000000",
      "editorIndentGuide.background1": "#e0e0e0",
      "editorIndentGuide.activeBackground1": "#a6a6a6",
      "editorBracketMatch.background": "#bdbdbd40",
      "editorBracketMatch.border": "#0031a9",
      // --- 错误/警告（CVD 适配：无红绿）---
      "editorError.foreground": "#9a4500",
      "editorWarning.foreground": "#6f5500",
      "editorInfo.foreground": "#0031a9",
      "list.errorForeground": "#9a4500",
      "list.warningForeground": "#6f5500",
      // --- Git 装饰（CVD 适配）---
      "gitDecoration.addedResourceForeground": "#00576e",
      "gitDecoration.modifiedResourceForeground": "#0031a9",
      "gitDecoration.deletedResourceForeground": "#9a4500",
      "gitDecoration.untrackedResourceForeground": "#005e8b",
      "gitDecoration.conflictingResourceForeground": "#721045",
      // --- Diff（CVD 适配）---
      "diffEditor.insertedTextBackground": "#00576e18",
      "diffEditor.removedTextBackground": "#9a450018",
      "diffEditor.insertedLineBackground": "#00576e12",
      "diffEditor.removedLineBackground": "#9a450012",
      // --- Workbench UI ---
      "sideBar.background": "#f7f7f7",
      "sideBar.foreground": "#000000",
      "sideBarTitle.foreground": "#000000",
      "activityBar.background": "#f0f0f0",
      "activityBar.foreground": "#000000",
      "statusBar.background": "#f0f0f0",
      "statusBar.foreground": "#000000",
      "statusBar.debuggingBackground": "#9a4500",
      "statusBar.debuggingForeground": "#ffffff",
      "titleBar.activeBackground": "#f0f0f0",
      "titleBar.activeForeground": "#000000",
      "tab.activeBackground": "#ffffff",
      "tab.inactiveBackground": "#f0f0f0",
      "tab.activeForeground": "#000000",
      "tab.inactiveForeground": "#595959",
      "panel.background": "#f7f7f7",
      "panel.border": "#e0e0e0",
      "focusBorder": "#0031a9",
      "selection.background": "#bdbdbd"
    }
  },
  // ══ Friday 语法高亮（CVD 适配：red→burnt orange, green→deep teal）══
  "editor.tokenColorCustomizations": {
    "[Default Light Modern]": {
      "comments": "#595959",
      "strings": "#00576e",
      "keywords": "#721045",
      "numbers": "#0031a9",
      "types": "#005e8b",
      "functions": "#0031a9",
      "variables": "#000000",
      "textMateRules": [
        {
          "scope": [
            "comment",
            "punctuation.definition.comment"
          ],
          "settings": {
            "foreground": "#595959",
            "fontStyle": "italic"
          }
        },
        {
          "scope": [
            "string",
            "string.quoted",
            "string.template"
          ],
          "settings": {
            "foreground": "#00576e"
          }
        },
        {
          "scope": [
            "keyword",
            "keyword.control",
            "keyword.operator.expression",
            "storage.modifier",
            "storage.type"
          ],
          "settings": {
            "foreground": "#721045",
            "fontStyle": "italic"
          }
        },
        {
          "scope": [
            "entity.name.function",
            "support.function",
            "meta.function-call"
          ],
          "settings": {
            "foreground": "#0031a9"
          }
        },
        {
          "scope": [
            "entity.name.type",
            "entity.name.class",
            "support.type",
            "support.class"
          ],
          "settings": {
            "foreground": "#005e8b"
          }
        },
        {
          "scope": [
            "variable",
            "variable.other",
            "variable.parameter"
          ],
          "settings": {
            "foreground": "#000000"
          }
        },
        {
          "scope": [
            "variable.language.this",
            "variable.language.self",
            "variable.language.super"
          ],
          "settings": {
            "foreground": "#721045",
            "fontStyle": "italic"
          }
        },
        {
          "scope": [
            "constant.numeric",
            "constant.language",
            "constant.character"
          ],
          "settings": {
            "foreground": "#0031a9"
          }
        },
        {
          "scope": [
            "entity.other.attribute-name"
          ],
          "settings": {
            "foreground": "#005e8b",
            "fontStyle": "italic"
          }
        },
        {
          "scope": [
            "entity.name.tag",
            "punctuation.definition.tag"
          ],
          "settings": {
            "foreground": "#0031a9"
          }
        },
        {
          "scope": [
            "markup.heading"
          ],
          "settings": {
            "foreground": "#0031a9",
            "fontStyle": "bold"
          }
        },
        {
          "scope": [
            "markup.bold"
          ],
          "settings": {
            "fontStyle": "bold"
          }
        },
        {
          "scope": [
            "markup.italic"
          ],
          "settings": {
            "fontStyle": "italic"
          }
        },
        {
          "scope": [
            "markup.inline.raw",
            "markup.fenced_code"
          ],
          "settings": {
            "foreground": "#9a4500"
          }
        },
        {
          "scope": [
            "markup.deleted"
          ],
          "settings": {
            "foreground": "#9a4500"
          }
        },
        {
          "scope": [
            "markup.inserted"
          ],
          "settings": {
            "foreground": "#00576e"
          }
        },
        {
          "scope": [
            "invalid",
            "invalid.illegal"
          ],
          "settings": {
            "foreground": "#9a4500"
          }
        },
        {
          "scope": [
            "support.constant",
            "constant.other"
          ],
          "settings": {
            "foreground": "#531ab6"
          }
        },
        {
          "scope": [
            "entity.other.inherited-class"
          ],
          "settings": {
            "foreground": "#005e8b",
            "fontStyle": "italic"
          }
        },
        {
          "scope": [
            "punctuation.definition.string",
            "punctuation.separator",
            "punctuation.terminator"
          ],
          "settings": {
            "foreground": "#000000"
          }
        },
        {
          "scope": [
            "meta.property-name",
            "support.type.property-name"
          ],
          "settings": {
            "foreground": "#6f5500"
          }
        },
        {
          "scope": [
            "variable.other.property",
            "variable.other.object.property"
          ],
          "settings": {
            "foreground": "#6f5500"
          }
        },
        {
          "scope": [
            "keyword.operator",
            "keyword.operator.assignment"
          ],
          "settings": {
            "foreground": "#000000"
          }
        },
        {
          "scope": [
            "meta.decorator",
            "punctuation.decorator"
          ],
          "settings": {
            "foreground": "#531ab6"
          }
        }
      ]
    }
  },
  // ══ 编辑器体验 ══
  "editor.tabSize": 2,
  "editor.lineNumbers": "relative",
  "editor.cursorBlinking": "smooth",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.guides.indentation": true,
  "editor.guides.highlightActiveIndentation": true,
  "editor.minimap.enabled": true,
  "editor.minimap.renderCharacters": false,
  "editor.minimap.maxColumn": 80,
  "editor.minimap.autohide": true,
  "editor.stickyScroll.enabled": true,
  "editor.stickyScroll.maxLineCount": 3,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.linkedEditing": true,
  "editor.renderWhitespace": "boundary",
  "editor.wordWrap": "off",
  "editor.rulers": [
    120
  ],
  "editor.inlayHints.enabled": "onUnlessPressed",
  "editor.inlayHints.fontSize": 12,
  "diffEditor.ignoreTrimWhitespace": false,
  // ══ 终端 ══
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  // ══ Workbench 行为 ══
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.compactFolders": false,
  "workbench.editor.tabSizing": "shrink",
  "workbench.editor.enablePreview": true,
  "workbench.editor.highlightModifiedTabs": "left",
  "workbench.startupEditor": "none",
  "workbench.list.smoothScrolling": true,
  "workbench.tree.indent": 16,
  "workbench.settings.applyToAllProfiles": [],
  // ══ 语言 Formatter ══
  "[vue]": {
    "editor.defaultFormatter": "Vue.volar"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[less]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[sql]": {
    "editor.defaultFormatter": "cweijan.vscode-database-client2"
  },
  "[go]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "golang.go",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.tabSize": 4,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.wordWrap": "on"
  },
  // ══ ESLint ══
  "eslint.enable": true,
  "eslint.useFlatConfig": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "vue"
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  // ══ 文件清理 ══
  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.associations": {
    "*.vue": "vue"
  },
  // ══ 语言 & 工具 ══
  "go.formatTool": "goimports",
  "go.toolsManagement.autoUpdate": true,
  "go.alternateTools": {
    "dlv": "/opt/homebrew/bin/dlv"
  },
  "go.lintTool": "golangci-lint",
  "go.lintOnSave": "workspace",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "json.schemas": [],
  // ══ Git ══
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.openRepositoryInParentFolders": "never",
  "gitlens.graph.layout": "editor",
  "gitlens.codeLens.enabled": false,
  // ══ 扩展 ══
  "database-client.autoSync": true,
  "redhat.telemetry.enabled": true,
  "console-ninja.featureSet": "Community",
  "console-ninja.fontSize": 14,
  "makefile.configureOnOpen": true,
  "security.promptForLocalFileProtocolHandling": false,
  "keyboard.dispatch": "keyCode",
  // ══ 代理（按需修改）══
  // "http.proxy": "http://127.0.0.1:6152",
  // "http.proxyStrictSSL": false,
  // ══ Claude Code ══
  "claudeCode.useTerminal": true,
  "claudeCode.environmentVariables": [],
  // ══ VSCode-Neovim ══
  "vscode-neovim.neovimExecutablePaths.darwin": "/opt/homebrew/bin/nvim",
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  }
}